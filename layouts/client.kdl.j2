{# NOTE: This file is not used at runtime. The actual template is inlined
   in src/cw/zellij.py as CLIENT_LAYOUT_TEMPLATE for reliable packaging
   with uv tool install. This file is kept as a human-readable reference. #}

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }

    tab name="{{ client_name }}" {
        pane split_direction="vertical" {
            // Idea pane - primary workspace (left, 50%)
            pane size="50%" name="idea" focus=true {
                cwd "{{ workspace_path }}"
            }
            // Impl + debt stacked on the right (50%)
            pane split_direction="horizontal" size="50%" {
                pane name="impl" {
                    cwd "{{ workspace_path }}"
                }
                pane size="30%" name="debt" {
                    cwd "{{ workspace_path }}"
                }
            }
        }
    }
}
