layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }

    tab name="{{ client_name }}" focus=true {
        pane split_direction="vertical" {
            // File tree (yazi) - left sidebar
            pane size="20%" name="files" {
                command "yazi"
                args "{{ workspace_path }}"
            }
            // Main work area
            pane split_direction="horizontal" size="80%" {
                // Primary implementation pane
                pane size="70%" name="impl" focus=true {
                    cwd "{{ workspace_path }}"
                }
                // Secondary panes row
                pane split_direction="vertical" size="30%" {
                    pane name="idea" {
                        cwd "{{ workspace_path }}"
                    }
                    pane name="debt" {
                        cwd "{{ workspace_path }}"
                    }
                }
            }
        }
    }

    tab name="{{ client_name }}-explore" {
        pane name="explore" {
            cwd "{{ workspace_path }}"
        }
    }
}
